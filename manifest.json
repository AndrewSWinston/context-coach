{
  "manifest_version": 3,
  "name": "ContextCoach",
  "version": "0.1.0",
  "description": "Counts token context size on claude.ai and recommends when to start a new chat.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://claude.ai/*", "https://chatgpt.com/*", "https://api.anthropic.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "ContextCoach"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
